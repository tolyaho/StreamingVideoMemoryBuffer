{
  "benchmark": "StreamingBench",
  "manifest": "data/eval_manifest_50.json",
  "videos": 50,
  "qas": 250,
  "reasoner_type": "vlm",
  "reasoner_model": "Qwen/Qwen3-VL-8B-Instruct",
  "config": "vlm_streaming",
  "command": "scripts/run_streamingbench_vlm.sh",
  "note": "Early VLM config (vlm_streaming). See vlm_full in eval_common.py for the intended full-memory setup.",
  "hyperparameters": {
    "top_m": 1,
    "top_k": 3,
    "tau_fraction": 0.10,
    "neighbor_radius": 0,
    "recent_episodes": 2,
    "pin_recent_n": 10,
    "reasoner_max_frames": 6,
    "include_coarse_text": false,
    "include_episodic_text": false,
    "ground_episodic_archive": false
  }
}
